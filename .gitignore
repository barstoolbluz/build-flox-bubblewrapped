# Flox build outputs — symlinks into /nix/store.  Not source.
/result-*
*.prevOutPath

# Build-time generated seccomp BPF blob (arch-specific, produced by
# gen-seccomp.c at build time and embedded into the Go binary via
# //go:embed).  Not checked in; the nix preBuild step generates it.
/tiocsti.bpf

