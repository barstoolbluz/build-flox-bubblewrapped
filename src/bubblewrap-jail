#!/usr/bin/env bash
#
# bubblewrap-jail — opinionated bubblewrap wrapper with secure defaults.
#
# Subcommands:
#   run     Jail a command.  Minimal fs view, no project binding, no secrets.
#   agent   Jail an agent.   Project dir rw, persistent agent home, API key
#           passthrough.  Defaults to --net.
#
# Threat model (v1): prompt-injection defense.
#   - Agent/command is buggy or steerable but not actively malicious.
#   - Must not be able to read SSH keys, GPG keys, cloud creds, or arbitrary
#     $HOME/* paths outside a small allowlist.
#   - Accept that a net-enabled sandbox can still exfiltrate anything visible
#     *inside* the jail — that's the cost of reaching APIs.
#
# Lifecycle and signals (deliberate, tested):
#   - --die-with-parent (PR_SET_PDEATHSIG → SIGKILL): the sandbox dies if
#     the launcher dies.  An orphaned wrapper invocation cannot outlive
#     the process that called it.
#   - --unshare-pid: the sandbox has its own PID namespace, so when bwrap
#     exits, every process inside the sandbox is reaped by the kernel.
#     There are no orphan jail processes after wrapper exit.
#   - exec bwrap: the wrapper exec()s bwrap as its final action, so the
#     wrapper's exit code IS bwrap's exit code IS the user command's exit
#     code (or 128+signal if the command was killed).  No intermediate
#     shell layer swallows codes or signals.
#   - Signal forwarding: bwrap forwards SIGTERM/SIGINT/SIGHUP to the
#     sandboxed child by default.  `timeout(1)` and Ctrl-C work as
#     expected against the wrapper.
#
# Precedence for configurable values: flags > env vars > compiled defaults.
#
# This script is deliberately self-contained — no sourced helpers, no config
# files, no external state.  Audit by reading this one file.

set -euo pipefail

# Hardcoded rather than $(basename "$0") so --help and error messages always
# identify this tool as "bubblewrap-jail" regardless of how it was invoked.
# Historically this defended against pre-v0.5.0 Flox manifest builds, which
# wrapped the installed binary in a PATH-setup shim and exposed the real
# script as .bubblewrap-jail-wrapped — without the hardcode, `--help` would
# have said `Usage: .bubblewrap-jail-wrapped`.  v0.5.0+ nix-expression builds
# install the real script directly (no shim), so `basename "$0"` would return
# the right value naturally, but the hardcode stays as a defense against any
# future re-wrapping and against callers that set argv[0] unusually.
prog="bubblewrap-jail"

# Path to the precompiled seccomp BPF blob that blocks ioctl(TIOCSTI, ...).
# Substituted at build time by the flox build step (see manifest.toml).
# When this script is run from source (development), the placeholder is
# unsubstituted and the seccomp filter is skipped with a stderr warning.
BPF_PATH="@BPF_PATH@"

# Wrapper version string, substituted at build time (extracted from the
# nix store path in the build command).  Used by `check --json` for the
# wrapper_version field so consumers can tell which wrapper they're
# talking to.  Source-mode runs carry the unsubstituted placeholder.
VERSION="@VERSION@"

err() { printf '%s: %s\n' "$prog" "$*" >&2; }
die() { err "$*"; exit 1; }

usage() {
  # Use printf (a bash builtin) rather than cat so --help works even when
  # PATH is empty / bwrap and coreutils are unavailable.
  printf '%s\n' "\
Usage: $prog <subcommand> [options] -- CMD [ARGS...]

Subcommands:
  run       Jail a command.  Minimal filesystem view, no project binding.
  agent     Jail an agent.   Project dir rw, persistent agent home.
  flox-env  Jail a Flox environment as a hardened container.  The sandbox
            sees only the Flox env's closure (immutable mode) or the full
            /nix/store rw (mutable mode, --mutable).  The env is activated
            via \`flox activate\` inside the sandbox.  Requires nix-store
            and flox on PATH at invocation time (not inside the sandbox).
            Pass \`-d DIR\` for a local env or \`-r OWNER/NAME\` for a remote
            Flox catalog env.  See \"flox-env options\" below.
  check     Probe the host for required bwrap/kernel features.  Reports
            PASS/FAIL/OPT per check and exits 0 (all required green) or
            1 (anything required red).  Optional features report on OPT
            lines and don't affect the exit code.  Pass \`--json\` for a
            machine-readable document (schema bubblewrap-jail-check/1)
            instead of the human-readable text output.
  doctor    Alias for \`check\`.  Same output, same exit code.

Common options:
  --net             Enable network (adds TLS certs, DNS, hosts).
  --no-net          Disable network.
  --bind SRC DST    Additional rw bind: mount host SRC at jail path DST.
                    Argument order matches bwrap(1).  May repeat.  DST
                    must not shadow an FHS-essential dir (/, /bin, /sbin,
                    /usr, /lib, /lib64, /etc, /proc, /dev, /nix); use
                    --bind-force to override.
  --ro-bind SRC DST Additional ro bind: mount host SRC at jail path DST.
                    Argument order matches bwrap(1).  May repeat.  Same
                    DST guard as --bind.
  --bind-force      Disable the essential-dir shadowing guard for user
                    --bind / --ro-bind.  For advanced users who genuinely
                    need to bind on top of /usr or similar.
  --setenv K V      Allowlist additional environment variable (may repeat).
  --hostname NAME   Sandbox hostname (default: bubblewrap-jail).
  --no-seccomp      Disable the default TIOCSTI-blocking seccomp filter.
                    Not recommended.  Exists for debugging and for running
                    the script from an unbuilt source tree.
  --lock-file PATH  Pass through to bwrap: hold an exclusive flock on PATH
                    for the lifetime of the sandbox.  PATH must already
                    exist on the host (bwrap does not create it).  The
                    wrapper auto-binds PATH rw into the jail at the same
                    path so bwrap can open it.  Useful for orchestrators
                    that want to wait for the sandbox to exit (acquire
                    the lock once released).
  --sync-fd FD      Pass through to bwrap: bwrap holds FD open for the
                    lifetime of the sandbox.  When the sandbox exits, FD
                    closes — a parent reading the other end of a pipe
                    sees EOF and knows the sandbox is gone.  FD must
                    already be open in the parent and inherited by the
                    wrapper (e.g. \`$prog run --sync-fd 9 ... 9>pipe\`).
  --info-fd FD      Pass through to bwrap: bwrap writes a JSON metadata
                    blob to FD after sandbox setup and closes it.  The
                    JSON includes the sandboxed child's host-side PID
                    among other fields; see bwrap(1) for the schema.
                    Useful for orchestrators that want structured info
                    without parsing stderr.  FD must already be open in
                    the parent and inherited by the wrapper.
  -h, --help        This help.

Agent-only options:
  --project DIR     Project dir to bind rw.
                    Default: \$BUBBLEWRAP_JAIL_PROJECT or \$PWD.
                    (\$FLOX_ENV_PROJECT is NOT used as a fallback; it points at
                    the tool env when layered, which is almost never correct.)
  --project-as DIR  Map the project dir to a synthetic path DST inside the
                    jail.  Host SRC is still the project dir above, but inside
                    the jail it appears at DST (and cwd is DST).  Default:
                    bind same-path (no remapping).  Use this when you want
                    stronger structural isolation, at the cost of breaking
                    tools that embed absolute paths in caches, debug info,
                    venvs, or linked git worktrees.
  --project-ro      Bind the project read-only.  Default is rw.  Useful
                    for read-only review/inspection workflows where the
                    agent should not be able to mutate the source tree.
  --agent-home DIR  Persistent agent HOME.
                    Default: \$FLOX_ENV_CACHE/agent-home, else
                    \${XDG_CACHE_HOME:-\$HOME/.cache}/bubblewrap-jail/agent-home.
  --passthrough-env VAR
                    Name of a host env var to pass through into the jail.
                    Repeatable: pass multiple times to allowlist multiple
                    vars.  Each var is set inside the jail only if the
                    host has it set; unset vars are silently skipped.
                    Default (when no --passthrough-env is given): the
                    BUBBLEWRAP_JAIL_PASSTHROUGH_ENV env var (comma-
                    separated list, e.g. \"A,B,C\") or ANTHROPIC_API_KEY.
                    Reserved names that the jail manages itself (PATH,
                    HOME, TMPDIR, TERM, LANG, PWD) are rejected per-entry.
                    Also valid in flox-env mode.

flox-env-only options:
  -d DIR            Local Flox environment directory.  Must contain a
                    .flox/run/ directory (run \`flox activate\` there once
                    first to populate it).  Mutually exclusive with -r.
  -r OWNER/NAME     Remote Flox catalog environment.  The wrapper runs
                    \`flox pull -r OWNER/NAME\` before setting up the sandbox.
                    Requires flox auth (\`flox auth login\`) for private
                    envs.  Mutually exclusive with -d.
  --mutable         Bind /nix/store and /nix/var read-write.  Required for
                    \`flox install\` inside the sandbox.  SECURITY TRADE-OFF:
                    exposes the full host /nix/store and lets the sandbox
                    mutate the host nix database via the daemon socket.
                    Default: immutable (closure-scoped, read-only).
                    Limitation: source-build installs (non-cache-hit) fail
                    because nix-build uses its own userns-based sandbox,
                    which cannot nest under --disable-userns.
  --x11             Bind the X socket at /tmp/.X11-unix/X\$DISPLAY_NUM and
                    \$HOME/.Xauthority.  Exposes the host X server to the
                    sandbox; only use with trusted content.
  --gpu             Bind /dev/dri, /sys/dev/char, /sys/devices/pci0000:00,
                    and /run/opengl-driver.  For ML/CUDA workloads.
  --dev-shm         Bind /dev/shm rw (databases, SHM IPC).
  --dry-run         Print the bwrap argv that would be executed and exit
                    without running bwrap.  Useful for auditing the sandbox
                    policy before committing to it.
  --no-activate     Skip the \`flox activate\` wrapper and run the command
                    directly inside the sandbox.  For debugging the sandbox
                    structure itself; most use cases want the default.

Environment variables (used as defaults; flags override):
  BUBBLEWRAP_JAIL_NET             0|1    (default: 0 for run, 1 for agent)
  BUBBLEWRAP_JAIL_PROJECT         path   (default project dir, agent only)
  BUBBLEWRAP_JAIL_HOME            path   (default agent home, agent only)
  BUBBLEWRAP_JAIL_PASSTHROUGH_ENV csv    (default: ANTHROPIC_API_KEY;
                                          comma-separated for multi-var)

Defaults:
  run mode:   net off; HOME=/tmp; cwd=/tmp; no project binding.
  agent mode: net on;  HOME=<agent-home>;
              cwd=<project> (or <project-as> if --project-as is set);
              host \$PATH inherited; API key passed through if set on host;
              host ~/.gitconfig ro-bound if present.

Environment in jail (everything is --clearenv'd, then explicitly added):
  Both modes always set:
    PATH    /usr/bin:/bin:/usr/sbin:/sbin
    TERM    inherited from host (default \"dumb\")
    LANG    inherited from host (default \"C.UTF-8\")
  run mode also sets:
    HOME    /tmp
    TMPDIR  /tmp
    (cwd:   /tmp; --new-session, no controlling tty)
  agent mode also sets:
    HOME    <agent-home>
    TMPDIR  /tmp
    PATH    overridden with host \$PATH (so Flox/Nix tools resolve)
    (cwd:   <project> or <project-as>; controlling tty preserved)
    each var named by --passthrough-env that's set on the host
  Plus any --setenv K V the user passed (run or agent), applied last so
  user --setenv wins.

Not mounted by default (i.e. hidden from the jail unless you explicitly
re-expose them with --bind / --ro-bind):
  ~/.ssh  ~/.gnupg  ~/.aws  ~/.config
  /etc/shadow  /etc/ssh  /etc/sudoers  /etc/pam.d
  any \$HOME/* path not explicitly allowlisted

Treat this list as a policy, not a guarantee.  If you pass
  --bind \$HOME/.ssh \$HOME/.ssh
the ssh keys will be visible inside the jail.  User-supplied binds are
applied AFTER the default policy and can therefore re-expose anything.

Mount ordering (bwrap applies operations in argv order; later wins):
  1. Skeleton ro:  /usr /bin /sbin /lib /lib64 /nix
  2. /etc tmpfs + ro-bind allowlist (passwd, group, ld.so.*, nsswitch,
     localtime, etc.).  Critically NOT bound: shadow, sudoers, ssh, pam.d.
  3. Fresh tmpfs:  /proc /dev /tmp /var/tmp /run
  4. Network:      ro-bind resolv.conf, hosts, ssl, ca-certs (or
                   --unshare-net if --no-net)
  5. Environment:  --clearenv then explicit --setenv (see \"Environment
                   in jail\" above)
  6. Mode binds:   agent → project (rw or ro), agent-home, gitconfig,
                   passthrough env vars
                   run   → HOME=/tmp, --new-session
  7. User extras:  --bind, --ro-bind, --setenv (so user can re-expose
                   anything from the default policy or layer on more)
  8. Lifecycle:    --lock-file, --sync-fd, --info-fd (if passed)
  9. Seal:         --remount-ro /etc (the tmpfs becomes ro; existing
                   bind mounts on top of it survive)
  10. Safety:      --seccomp (TIOCSTI BPF blob)"
}

# NOTE: no "bwrap present?" check here on purpose.  We want --help and
# bad-subcommand errors to work even when bwrap isn't installed.  The actual
# dependency check happens right before exec bwrap at the bottom of the file.

# -----------------------------------------------------------------------------
# check subcommand: compat probe
# -----------------------------------------------------------------------------

run_check() {
  # Parse check-specific flags.  --json switches to machine-readable
  # output; default is human-readable text.  -h/--help prints the full
  # usage (same as the top-level subcommand dispatcher) and exits 0, so
  # `bubblewrap-jail check --help` works as users expect.
  #
  # The unknown-option die message deliberately does NOT prefix with
  # "check:" — the err() helper already prefixes "bubblewrap-jail:",
  # and adding a subcommand label here would be inconsistent with the
  # rest of the wrapper's error messages (and would say "check:" even
  # when called via the `doctor` alias, which is wrong).
  local output_format=text
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json)    output_format=json; shift ;;
      -h|--help) usage; exit 0 ;;
      *)         die "unknown option: $1" ;;
    esac
  done

  local checks_passed=0 checks_failed=0 opt_present=0 opt_missing=0
  local help_out flag ver mun bsz
  # Probe records are collected in parallel arrays.  In text mode we
  # also print each probe line in real time; in json mode we only emit
  # at the end via _emit_check_json.
  local -a probe_names=() probe_statuses=()

  # These are function definitions, not variables — shellcheck gets confused
  # if they appear in a `local` declaration.  Function scope in bash is global
  # regardless of where they're defined, but that's fine for our use.
  pass_msg() {
    probe_names+=("$1"); probe_statuses+=("pass")
    checks_passed=$((checks_passed+1))
    # `if/then/fi` (not `&&`) so the function returns 0 in both
    # text and json modes — an `&&` whose left side is false would
    # propagate a 1 return status and trip `set -e` in the caller.
    if [ "$output_format" = text ]; then
      printf '  PASS  %s\n' "$1"
    fi
  }
  fail_msg() {
    # For record purposes, we store just the name; the detail (if any)
    # goes in the text-mode line.  JSON consumers match on name.
    local fail_name=$1
    if [ $# -ge 2 ] && [ -n "$2" ]; then
      fail_name="$1 — $2"
    fi
    probe_names+=("$fail_name"); probe_statuses+=("fail")
    checks_failed=$((checks_failed+1))
    if [ "$output_format" = text ]; then
      if [ $# -ge 2 ] && [ -n "$2" ]; then
        printf '  FAIL  %s — %s\n' "$1" "$2"
      else
        printf '  FAIL  %s\n' "$1"
      fi
    fi
  }
  # Optional: probe succeeded (feature supported) but missing would NOT be
  # a failure — the wrapper only uses the flag if the user opts in at runtime.
  # Output prefix "OPT" is distinct from PASS/FAIL so parsers can tell them
  # apart.  Does not affect checks_passed or checks_failed.
  opt_msg() {
    if [ "$2" = "present" ]; then
      probe_names+=("bwrap supports $1"); probe_statuses+=("opt_supported")
      opt_present=$((opt_present+1))
      if [ "$output_format" = text ]; then
        printf '  OPT   bwrap supports %s  (optional: only needed if %s is passed at runtime)\n' "$1" "$1"
      fi
    else
      probe_names+=("bwrap supports $1"); probe_statuses+=("opt_missing")
      opt_missing=$((opt_missing+1))
      if [ "$output_format" = text ]; then
        printf '  OPT   bwrap missing  %s  (optional: %s will fail if used)\n' "$1" "$1"
      fi
    fi
  }
  # opt_external NAME STATUS DETAIL — record an optional external-tool
  # probe (separate from the bwrap-feature opt_msg above).  Used by the
  # flox-env subcommand's runtime-dep probes: nix-store, flox CLI, /etc/nix.
  # NAME is the full probe name stored in JSON; DETAIL is the text-mode
  # annotation appended after the name.
  opt_external() {
    local name=$1 status=$2 detail=$3
    if [ "$status" = "present" ]; then
      probe_names+=("$name"); probe_statuses+=("opt_supported")
      opt_present=$((opt_present+1))
      if [ "$output_format" = text ]; then
        if [ -n "$detail" ]; then
          printf '  OPT   %s  (%s)\n' "$name" "$detail"
        else
          printf '  OPT   %s\n' "$name"
        fi
      fi
    else
      probe_names+=("$name"); probe_statuses+=("opt_missing")
      opt_missing=$((opt_missing+1))
      if [ "$output_format" = text ]; then
        if [ -n "$detail" ]; then
          printf '  OPT   %s  (missing — %s)\n' "$name" "$detail"
        else
          printf '  OPT   %s  (missing)\n' "$name"
        fi
      fi
    fi
  }

  # JSON string escaper: handles backslash, double quote, and control
  # characters (newline, tab, carriage return).  Our probe data is
  # ASCII-clean in practice, but defensive escaping keeps the output
  # valid even if a future probe emits a weird string.  CRITICAL:
  # escape backslash FIRST, otherwise later escape substitutions get
  # double-escaped.
  _json_str() {
    local s=$1
    s=${s//\\/\\\\}
    s=${s//\"/\\\"}
    s=${s//$'\n'/\\n}
    s=${s//$'\t'/\\t}
    s=${s//$'\r'/\\r}
    printf '"%s"' "$s"
  }

  # Emit the collected probe records as a JSON document on stdout.
  # Schema version pinned to "bubblewrap-jail-check/1".  Within this
  # schema, probe NAMES are stable — consumers can match on them.
  # Adding a new probe is non-breaking and stays at /1; renaming,
  # removing, or changing the semantics of an existing probe bumps
  # to /2.
  _emit_check_json() {
    local i n ok=false
    [ "$checks_failed" -eq 0 ] && ok=true
    n=${#probe_names[@]}
    printf '{\n'
    printf '  "schema": "bubblewrap-jail-check/1",\n'
    printf '  "wrapper_version": %s,\n' "$(_json_str "$VERSION")"
    # Empty-probes case is unreachable in current usage (every code
    # path records at least one probe), but emit the short form `[]`
    # defensively so an empty emitter call produces clean JSON instead
    # of `[\n  ]`.
    if [ "$n" -eq 0 ]; then
      printf '  "probes": [],\n'
    else
      printf '  "probes": [\n'
      for ((i=0; i<n; i++)); do
        printf '    {"name": %s, "status": %s}' \
          "$(_json_str "${probe_names[i]}")" \
          "$(_json_str "${probe_statuses[i]}")"
        if [ "$i" -lt "$((n-1))" ]; then
          printf ',\n'
        else
          printf '\n'
        fi
      done
      printf '  ],\n'
    fi
    printf '  "summary": {\n'
    printf '    "passed": %d,\n'        "$checks_passed"
    printf '    "failed": %d,\n'        "$checks_failed"
    printf '    "opt_supported": %d,\n' "$opt_present"
    printf '    "opt_missing": %d,\n'   "$opt_missing"
    printf '    "ok": %s\n'             "$ok"
    printf '  }\n'
    printf '}\n'
  }

  if [ "$output_format" = text ]; then
    printf '=== bubblewrap-jail compat probe ===\n'
  fi

  # bwrap present and runnable?
  if command -v bwrap >/dev/null 2>&1; then
    pass_msg "bwrap in PATH ($(command -v bwrap))"
  else
    fail_msg "bwrap not found in PATH"
    if [ "$output_format" = text ]; then
      printf '=== result: %d passed, %d failed; optional: %d supported / %d missing ===\n' \
        "$checks_passed" "$checks_failed" "$opt_present" "$opt_missing"
    else
      _emit_check_json
    fi
    return 1
  fi

  # bwrap version
  ver=$(bwrap --version 2>/dev/null | awk '{print $NF; exit}')
  if [ -n "$ver" ]; then
    pass_msg "bwrap version: $ver"
  else
    fail_msg "bwrap --version returned nothing parseable"
  fi

  # bwrap features split into REQUIRED and OPTIONAL lists.
  #
  # Required: the wrapper passes these on every invocation.  Missing any
  # one is a hard failure — the wrapper cannot function.  This list MUST
  # stay in sync with the flags the wrapper actually passes at runtime
  # for run/agent mode.
  #
  # Optional: the wrapper only passes these when the user opts in via a
  # corresponding flag (--lock-file PATH, --sync-fd FD, --info-fd FD).
  # Missing these on the host bwrap is fine if the user doesn't use
  # those features.  Reported with an OPT line so the user knows which
  # wrapper features will be unavailable on this host.
  #
  # The grep uses a word-boundary pattern ((^|space) flag (space|eol)) so
  # that --bind does NOT false-positive on --bind-try / --bind-data, --dev
  # on --dev-bind, and --ro-bind on --ro-bind-try.  A plain substring match
  # would let a hypothetical bwrap that shipped only the -try variants pass
  # the probe silently.  Today no bwrap release has that split, but the
  # probe should be semantically correct regardless.
  help_out=$(bwrap --help 2>/dev/null)

  # Required probes.
  for flag in \
      --unshare-user --unshare-ipc --unshare-pid --unshare-uts \
      --unshare-cgroup-try --unshare-net \
      --disable-userns --assert-userns-disabled \
      --die-with-parent --hostname --new-session \
      --bind --ro-bind --ro-bind-try \
      --tmpfs --proc --dev --remount-ro \
      --clearenv --setenv --chdir --seccomp
  do
    if printf '%s' "$help_out" | grep -qE -- "(^|[[:space:]])${flag}([[:space:]]|$)"; then
      pass_msg "bwrap supports $flag"
    else
      fail_msg "bwrap missing feature" "$flag"
    fi
  done

  # Optional probes (opt-in via corresponding wrapper flag).
  for flag in --lock-file --sync-fd --info-fd
  do
    if printf '%s' "$help_out" | grep -qE -- "(^|[[:space:]])${flag}([[:space:]]|$)"; then
      opt_msg "$flag" present
    else
      opt_msg "$flag" missing
    fi
  done

  # flox-env runtime deps (OPT — only needed for the flox-env subcommand).
  # These don't affect the exit code; missing just means flox-env won't work
  # on this host.  The probes live here so `bubblewrap-jail check` tells
  # users upfront whether flox-env is usable.
  if command -v nix-store >/dev/null 2>&1; then
    opt_external "flox-env: nix-store available" present "$(command -v nix-store)"
  else
    opt_external "flox-env: nix-store available" missing \
      "required for closure computation in flox-env immutable mode"
  fi
  if command -v flox >/dev/null 2>&1; then
    _flox_ver=$(flox --version 2>/dev/null | awk '{print $NF; exit}')
    opt_external "flox-env: flox CLI available" present "${_flox_ver:-unknown version}"
    unset _flox_ver
  else
    opt_external "flox-env: flox CLI available" missing \
      "required by the flox-env subcommand"
  fi
  if [ -d /etc/nix ]; then
    opt_external "flox-env: /etc/nix present" present ""
  else
    opt_external "flox-env: /etc/nix present" missing \
      "activation inside flox-env sandbox will fail without /etc/nix"
  fi

  # Kernel sysctls / caps
  if [ -r /proc/sys/user/max_user_namespaces ]; then
    mun=$(cat /proc/sys/user/max_user_namespaces 2>/dev/null || echo 0)
    if [ "$mun" -gt 0 ] 2>/dev/null; then
      pass_msg "kernel user namespaces enabled (max_user_namespaces=$mun)"
    else
      fail_msg "user namespaces disabled" "user.max_user_namespaces=0"
    fi
  else
    fail_msg "cannot read /proc/sys/user/max_user_namespaces"
  fi

  # End-to-end smoke: can bwrap build and enter a minimal sandbox?
  if bwrap --ro-bind / / --disable-userns --assert-userns-disabled \
           --unshare-user --unshare-pid --die-with-parent \
           true 2>/dev/null
  then
    pass_msg "minimal bwrap launch works"
  else
    fail_msg "minimal bwrap launch failed"
  fi

  # /nix store presence
  if [ -d /nix/store ]; then
    pass_msg "/nix/store present"
  else
    fail_msg "/nix/store absent (non-Nix host)" "many flox-packaged tools won't resolve"
  fi

  # Seccomp BPF blob shipped with this installation?  Two checks: (1) the
  # file is readable, (2) bwrap will actually accept it via --seccomp.  The
  # second catches a corrupted/truncated blob or a kernel that rejects the
  # filter at prctl(PR_SET_SECCOMP) time.
  case "$BPF_PATH" in
    /*)
      if [ -r "$BPF_PATH" ]; then
        bsz=$(wc -c <"$BPF_PATH" 2>/dev/null || echo 0)
        pass_msg "seccomp BPF readable ($bsz bytes at $BPF_PATH)"
        if bwrap --ro-bind / / --disable-userns --assert-userns-disabled \
                 --unshare-user --unshare-pid --die-with-parent \
                 --seccomp 11 11<"$BPF_PATH" \
                 true 2>/dev/null
        then
          pass_msg "seccomp BPF loads into bwrap"
        else
          fail_msg "seccomp BPF present but bwrap rejected it"
        fi
      else
        fail_msg "seccomp BPF not readable at $BPF_PATH"
      fi
      ;;
    *)
      fail_msg "seccomp BPF path not substituted (running from unbuilt source?)"
      ;;
  esac

  if [ "$output_format" = text ]; then
    printf '=== result: %d passed, %d failed; optional: %d supported / %d missing ===\n' \
      "$checks_passed" "$checks_failed" "$opt_present" "$opt_missing"
  else
    _emit_check_json
  fi
  [ "$checks_failed" -eq 0 ]
}

# -----------------------------------------------------------------------------
# flox-env helper functions
# -----------------------------------------------------------------------------
#
# Used only by the flox-env subcommand.  The env-resolution and closure-
# computation patterns below are ported (concept, not code) from
# devusb/flox-bwrap (MIT) — specifically the logic in its paths.go.  See
# ACKNOWLEDGMENTS.md for details.  We re-implement in bash so the wrapper
# stays self-contained and auditable as one file.
#
# Runtime dependencies (checked by the check subcommand as OPT probes):
#   - nix-store    for closure computation
#   - flox         for `flox pull` on remote envs

# resolve_local_env DIR
#   Emit the absolute store-path targets of each .flox/run/* symlink in DIR.
#   Bubblewrap-jail's own working tree is NOT a valid target here unless
#   `flox activate` has been run there at least once to populate .flox/run/.
resolve_local_env() {
  local env_dir=$1 abs_dir run_dir entry target
  [ -d "$env_dir" ] || die "flox-env: local env not a directory: $env_dir"
  abs_dir=$(cd "$env_dir" && pwd -P)
  run_dir="$abs_dir/.flox/run"
  [ -d "$run_dir" ] || die "flox-env: no .flox/run in $abs_dir (run 'flox activate' there once first to populate it)"
  local matched=0
  for entry in "$run_dir"/*; do
    [ -L "$entry" ] || continue
    target=$(readlink -f "$entry" 2>/dev/null) || continue
    case "$target" in
      /nix/store/*) printf '%s\n' "$target"; matched=1 ;;
    esac
  done
  [ "$matched" = 1 ] || die "flox-env: no valid /nix/store run symlinks in $run_dir"
}

# resolve_remote_env OWNER/NAME
#   Run `flox pull` to fetch the env, then emit the store-path targets of
#   matching symlinks under ~/.cache/flox/run/<owner>/.  Matches flox-bwrap's
#   parseRemoteEnvRequisites pattern (paths.go:76-128) at the env-resolution
#   level, but we don't call nix-store here — closure computation is the
#   caller's job.
resolve_remote_env() {
  local ref=$1 owner name run_dir entry target
  case "$ref" in
    */*) owner=${ref%%/*}; name=${ref#*/} ;;
    *)   die "flox-env: --remote-env expected owner/name, got: $ref" ;;
  esac
  command -v flox >/dev/null 2>&1 \
    || die "flox-env: flox CLI not on PATH (required to pull remote env $ref)"
  # flox pull writes to stdout; redirect to stderr so our own stdout stays
  # clean for the store-path output.  On failure, surface flox's own error.
  if ! flox pull -r "$ref" >&2; then
    die "flox-env: flox pull failed for $ref"
  fi
  run_dir="${HOME:-/tmp}/.cache/flox/run/$owner"
  [ -d "$run_dir" ] \
    || die "flox-env: no ~/.cache/flox/run/$owner after pull (flox layout changed?)"
  local matched=0
  for entry in "$run_dir"/*; do
    [ -L "$entry" ] || continue
    # Match "x86_64-linux.<name>.dev", ".run" and similar per-system forms.
    # We filter by the ".<name>." substring in the basename rather than a
    # stricter regex so we tolerate future layout changes without breaking.
    case "${entry##*/}" in
      *".$name."*) ;;
      *) continue ;;
    esac
    target=$(readlink -f "$entry" 2>/dev/null) || continue
    case "$target" in
      /nix/store/*) printf '%s\n' "$target"; matched=1 ;;
    esac
  done
  [ "$matched" = 1 ] || die "flox-env: no run symlinks for $ref in $run_dir"
}

# compute_closure PATH...
#   For each input store path, emit its transitive runtime closure via
#   nix-store --query --requisites.  Concatenates all results and dedups
#   via sort -u.  Port of flox-bwrap's getNixRequisites + dedup pattern
#   (paths.go:57-73, 174-184).
#
#   Errors out via die if nix-store is missing or fails, so callers can
#   trust the emitted list is complete.
compute_closure() {
  command -v nix-store >/dev/null 2>&1 \
    || die "flox-env: nix-store not on PATH (required for closure computation)"
  local p chunk all=""
  for p in "$@"; do
    if ! chunk=$(nix-store --query --requisites "$p" 2>&1); then
      die "flox-env: nix-store --query --requisites failed for $p: $chunk"
    fi
    all+="$chunk"$'\n'
  done
  printf '%s' "$all" | sort -u
}

# find_bash_in_closure PATH...
#   Emit the first closure path whose bin/bash is executable, as
#   "<path>/bin/bash".  Used to build /bin/sh and /bin/bash symlinks that
#   resolve into the Flox env's closure rather than host /bin.  Port of
#   the loop in flox-bwrap's paths.go:40-47.
#   Returns 1 with an empty stdout if nothing matches — caller must die
#   with a meaningful error.
find_bash_in_closure() {
  local p
  for p in "$@"; do
    if [ -x "$p/bin/bash" ]; then
      printf '%s/bin/bash\n' "$p"
      return 0
    fi
  done
  return 1
}

# -----------------------------------------------------------------------------
# Parse subcommand
# -----------------------------------------------------------------------------

if [ "$#" -lt 1 ]; then
  usage >&2
  die "missing subcommand"
fi

case "$1" in
  run|agent|flox-env) cmd=$1; shift ;;
  check|doctor) shift; run_check "$@"; exit $? ;;
  -h|--help)    usage; exit 0 ;;
  *)            usage >&2; die "unknown subcommand: $1" ;;
esac

# -----------------------------------------------------------------------------
# Parse options
# -----------------------------------------------------------------------------

net=""                    # "" = use subcommand default
project=""
project_as=""             # "" = same-path bind (no remapping)
project_ro=0              # 1 = bind project as --ro-bind instead of --bind (F1)
agent_home=""
extra_bind=()
extra_ro_bind=()
extra_setenv=()
hostname="bubblewrap-jail"
passthrough_envs=()       # list of env var names to pass through (E1)
passthrough_envs_set_by_flag=0  # tracks --passthrough-env for run-mode rejection
seccomp_enabled=1         # may be cleared by --no-seccomp
lock_file=""              # --lock-file PATH passthrough (V1)
sync_fd=""                # --sync-fd FD  passthrough (V1)
info_fd=""                # --info-fd FD  passthrough (observability)
bind_force=0              # --bind-force opts out of essential-dst guard (F2)
local_env=""              # flox-env: -d DIR (local Flox env directory)
remote_env=""             # flox-env: -r owner/name (remote Flox catalog env)
mutable=0                 # flox-env: --mutable (bind /nix/store + /nix/var rw)
x11=0                     # flox-env: --x11 (bind X socket + Xauthority)
gpu=0                     # flox-env: --gpu (bind /dev/dri + PCI + opengl-driver)
dev_shm=0                 # flox-env: --dev-shm (--dev-bind /dev/shm)
dry_run=0                 # flox-env: --dry-run (print argv and exit)
no_activate=0             # flox-env: --no-activate (skip flox activate wrapper)

while [ "$#" -gt 0 ]; do
  case "$1" in
    --net)           net=1; shift ;;
    --no-net)        net=0; shift ;;
    --bind)          [ "$#" -ge 3 ] || die "--bind needs SRC DST"
                     extra_bind+=("$2" "$3"); shift 3 ;;
    --ro-bind)       [ "$#" -ge 3 ] || die "--ro-bind needs SRC DST"
                     extra_ro_bind+=("$2" "$3"); shift 3 ;;
    --setenv)        [ "$#" -ge 3 ] || die "--setenv needs K V"
                     extra_setenv+=("$2" "$3"); shift 3 ;;
    --hostname)      [ "$#" -ge 2 ] || die "--hostname needs NAME"
                     hostname=$2; shift 2 ;;
    --project)       [ "$#" -ge 2 ] || die "--project needs DIR"
                     project=$2; shift 2 ;;
    --project-as)    [ "$#" -ge 2 ] || die "--project-as needs DIR"
                     project_as=$2; shift 2 ;;
    --project-ro)    project_ro=1; shift ;;
    --agent-home)    [ "$#" -ge 2 ] || die "--agent-home needs DIR"
                     agent_home=$2; shift 2 ;;
    --bind-force)    bind_force=1; shift ;;
    --passthrough-env)
                     [ "$#" -ge 2 ] || die "--passthrough-env needs VAR"
                     # Repeatable: each occurrence appends one var name.
                     passthrough_envs+=("$2")
                     passthrough_envs_set_by_flag=1
                     shift 2 ;;
    --no-seccomp)    seccomp_enabled=0; shift ;;
    --lock-file)     [ "$#" -ge 2 ] || die "--lock-file needs PATH"
                     # Pre-validate: bwrap will fail with a cryptic
                     # "Can't find source path" if the file is missing,
                     # so catch it early with our own message.
                     [ -e "$2" ] || die "--lock-file path does not exist: $2 (create it first; bwrap will not)"
                     lock_file=$2; shift 2 ;;
    --sync-fd)       [ "$#" -ge 2 ] || die "--sync-fd needs FD"
                     # bwrap requires a non-negative integer fd.
                     case "$2" in
                       ''|*[!0-9]*) die "--sync-fd must be a non-negative integer: $2" ;;
                     esac
                     # Reject fd 10 and 11 — the wrapper reserves those
                     # for the seccomp BPF (fd 10 is held across exec
                     # bwrap; fd 11 is used transiently by the C2
                     # pre-flight probe).  Accepting them would silently
                     # clobber the seccomp fd via `exec 10<` below.
                     #
                     # CRITICAL: use `[ -eq ]` (test-builtin arithmetic),
                     # NOT `$(( ))` arithmetic expansion.  `$(( 010 ))`
                     # evaluates to 8 because `$(( ))` follows C octal
                     # rules; `[ "010" -eq 10 ]` is TRUE because bash's
                     # test-builtin parses digit strings as decimal.
                     # Writing this as `$(( $2 )) -eq 10` would silently
                     # accept `--sync-fd 010` — the exact bug v0.4.3
                     # fixes.  If you "simplify" this to arithmetic
                     # expansion, add a test for `--sync-fd 010` and
                     # watch it fail.
                     #
                     # 2>/dev/null suppresses bash's overflow warning on
                     # pathological inputs (20+ digit numbers).  Those
                     # can't be 10 or 11 anyway, and bwrap will reject
                     # them at runtime as out-of-range.
                     if [ "$2" -eq 10 ] 2>/dev/null || [ "$2" -eq 11 ] 2>/dev/null; then
                       die "--sync-fd cannot be 10 or 11 (reserved by wrapper for seccomp BPF)"
                     fi
                     sync_fd=$2; shift 2 ;;
    --info-fd)       [ "$#" -ge 2 ] || die "--info-fd needs FD"
                     # Same fd 10/11 reservation and arithmetic-comparison
                     # caveats as --sync-fd above.
                     case "$2" in
                       ''|*[!0-9]*) die "--info-fd must be a non-negative integer: $2" ;;
                     esac
                     if [ "$2" -eq 10 ] 2>/dev/null || [ "$2" -eq 11 ] 2>/dev/null; then
                       die "--info-fd cannot be 10 or 11 (reserved by wrapper for seccomp BPF)"
                     fi
                     info_fd=$2; shift 2 ;;
    # flox-env subcommand options
    -d)              [ "$#" -ge 2 ] || die "-d needs DIR"
                     local_env=$2; shift 2 ;;
    -r)              [ "$#" -ge 2 ] || die "-r needs OWNER/NAME"
                     remote_env=$2; shift 2 ;;
    --mutable)       mutable=1; shift ;;
    --x11)           x11=1; shift ;;
    --gpu)           gpu=1; shift ;;
    --dev-shm)       dev_shm=1; shift ;;
    --dry-run)       dry_run=1; shift ;;
    --no-activate)   no_activate=1; shift ;;
    -h|--help)       usage; exit 0 ;;
    --)              shift; break ;;
    -*)              usage >&2; die "unknown option: $1" ;;
    *)               break ;;
  esac
done

[ "$#" -ge 1 ] || die "no command given"

# If no --passthrough-env flag was passed, seed the list from the env var
# default (comma-separated for multi-var support) or the compiled default.
# Empty entries from leading/trailing/double commas are stripped at use time.
if [ "$passthrough_envs_set_by_flag" = 0 ]; then
  IFS=',' read -ra passthrough_envs <<<"${BUBBLEWRAP_JAIL_PASSTHROUGH_ENV:-ANTHROPIC_API_KEY}"
fi

# Reject reserved env-var names that the jail manages itself.  Allowing
# these to be passthrough'd would override the jail's own baseline (e.g.
# --passthrough-env HOME would replace the jail HOME with the host HOME),
# defeating isolation.  Applied per-entry so each item in the list is
# checked independently — both flag-supplied and env-var-supplied.
for _pte in "${passthrough_envs[@]}"; do
  case "$_pte" in
    '')        continue ;;  # skip empty entries from "A,,B" or trailing comma
    PATH|HOME|TMPDIR|TERM|LANG|PWD)
               die "--passthrough-env may not be a reserved name: $_pte" ;;
  esac
done
unset _pte

# Reject agent-only flags in run mode so misuse is noisy, not silent.
# --passthrough-env needs its own tracking boolean because passthrough_envs
# always has a non-empty default, so we can't distinguish "user set it" from
# "default applied" by array emptiness.
#
# Note: the "agent-only" error-message strings for --project, --project-as,
# --agent-home, --project-ro, and --passthrough-env are load-bearing for the
# red-team test suite (test/red-team.sh anchors on them).  Keep them verbatim.
# --passthrough-env is also valid in flox-env mode, so its rejection is
# run-only, not agent+flox-env.
if [ "$cmd" = "run" ]; then
  [ -z "$project"    ] || die "--project is agent-only"
  [ -z "$project_as" ] || die "--project-as is agent-only"
  [ -z "$agent_home" ] || die "--agent-home is agent-only"
  [ "$project_ro" = 0 ] || die "--project-ro is agent-only"
  [ "$passthrough_envs_set_by_flag" = 0 ] || die "--passthrough-env is agent-only"
fi

# flox-env also rejects the agent project/home flags (they don't apply — the
# "project" in flox-env is the Flox env itself, and the home is a tmpfs).
if [ "$cmd" = "flox-env" ]; then
  [ -z "$project"    ] || die "--project is agent-only"
  [ -z "$project_as" ] || die "--project-as is agent-only"
  [ -z "$agent_home" ] || die "--agent-home is agent-only"
  [ "$project_ro" = 0 ] || die "--project-ro is agent-only"
fi

# Reject flox-env-only flags outside flox-env mode.
if [ "$cmd" != "flox-env" ]; then
  [ -z "$local_env"  ] || die "-d is flox-env-only"
  [ -z "$remote_env" ] || die "-r is flox-env-only"
  [ "$mutable"     = 0 ] || die "--mutable is flox-env-only"
  [ "$x11"         = 0 ] || die "--x11 is flox-env-only"
  [ "$gpu"         = 0 ] || die "--gpu is flox-env-only"
  [ "$dev_shm"     = 0 ] || die "--dev-shm is flox-env-only"
  [ "$dry_run"     = 0 ] || die "--dry-run is flox-env-only"
  [ "$no_activate" = 0 ] || die "--no-activate is flox-env-only"
fi

# flox-env: require exactly one of -d or -r
if [ "$cmd" = "flox-env" ]; then
  if [ -n "$local_env" ] && [ -n "$remote_env" ]; then
    die "flox-env: -d and -r are mutually exclusive"
  fi
  if [ -z "$local_env" ] && [ -z "$remote_env" ]; then
    die "flox-env: -d DIR or -r OWNER/NAME required"
  fi
fi

# F2: validate user --bind / --ro-bind destinations.  Reject paths that
# would shadow an FHS-essential directory and break the sandbox (the
# user has set up a bind that bwrap will accept and then bwrap's
# subsequent operations or the user command will fail because /bin or
# /usr is no longer there).  Sub-paths of essentials (e.g. /etc/foo,
# /usr/local/share/x) are allowed — that's the documented escape hatch
# for re-exposing specific files.  --bind-force opts out entirely for
# advanced users who know what they're doing.
if [ "$bind_force" = 0 ]; then
  _check_user_bind_dst() {
    case "$1" in
      / | /bin | /sbin | /usr | /lib | /lib64 | /etc | /proc | /dev | /nix)
        die "--bind/--ro-bind dst would shadow essential dir: $1 (use --bind-force to override)" ;;
    esac
  }
  i=0
  while [ $i -lt ${#extra_bind[@]} ]; do
    _check_user_bind_dst "${extra_bind[i+1]}"
    i=$((i + 2))
  done
  i=0
  while [ $i -lt ${#extra_ro_bind[@]} ]; do
    _check_user_bind_dst "${extra_ro_bind[i+1]}"
    i=$((i + 2))
  done
  unset -f _check_user_bind_dst
fi

# -----------------------------------------------------------------------------
# Resolve defaults
# -----------------------------------------------------------------------------

if [ -z "$net" ]; then
  if [ -n "${BUBBLEWRAP_JAIL_NET:-}" ]; then
    net=$BUBBLEWRAP_JAIL_NET
  elif [ "$cmd" = "agent" ]; then
    net=1
  else
    net=0
  fi
fi

case "$net" in
  0|1) ;;
  *)   die "invalid net value: $net (expected 0 or 1)" ;;
esac

if [ "$cmd" = "agent" ]; then
  # Project dir precedence: --project flag > BUBBLEWRAP_JAIL_PROJECT > $PWD.
  # We deliberately do NOT fall back to $FLOX_ENV_PROJECT: when this tool is
  # layered onto a different working directory via `flox activate -d`,
  # $FLOX_ENV_PROJECT points at the tool env itself, which is virtually never
  # what a user wants as the jailed project.  $PWD matches the user's intent
  # ("sandbox the thing I'm standing in").
  if [ -z "$project" ]; then
    project="${BUBBLEWRAP_JAIL_PROJECT:-$PWD}"
  fi
  [ -d "$project" ] || die "project dir not a directory: $project"
  project=$(cd "$project" && pwd -P)

  # Default: bind same-path inside as outside.  Tools that record absolute
  # paths (git worktrees, build caches, compiler debug info, Python venvs)
  # keep working across the jail boundary.
  if [ -z "$project_as" ]; then
    project_as=$project
  else
    # Must be absolute to be a valid bwrap bind target.
    case "$project_as" in
      /*) ;;
      *)  die "--project-as must be an absolute path: $project_as" ;;
    esac
    # Refuse to bind on top of FHS-essential paths.  bwrap will happily
    # shadow /bin or /usr with the project dir and then exec inside the
    # sandbox fails ("No such file or directory") because /bin/sh is gone.
    # Footgun, not a security boundary — but loud is better than silent.
    case "$project_as" in
      / | /bin | /sbin | /usr | /lib | /lib64 | /etc | /proc | /dev \
        | /tmp | /var | /run | /nix | /root | /home)
        die "--project-as cannot shadow essential directory: $project_as" ;;
      /bin/* | /sbin/* | /usr/* | /lib/* | /lib64/* | /etc/* \
        | /proc/* | /dev/* | /nix/*)
        die "--project-as cannot be under essential directory: $project_as" ;;
    esac
  fi

  if [ -z "$agent_home" ]; then
    if [ -n "${BUBBLEWRAP_JAIL_HOME:-}" ]; then
      agent_home=$BUBBLEWRAP_JAIL_HOME
    elif [ -n "${FLOX_ENV_CACHE:-}" ]; then
      agent_home="$FLOX_ENV_CACHE/agent-home"
    else
      agent_home="${XDG_CACHE_HOME:-${HOME:-/tmp}/.cache}/bubblewrap-jail/agent-home"
    fi
  fi
  mkdir -p "$agent_home"
  agent_home=$(cd "$agent_home" && pwd -P)
fi

# -----------------------------------------------------------------------------
# flox-env defaults resolution
# -----------------------------------------------------------------------------
#
# Resolve the target Flox env (local or remote), compute its runtime closure
# via nix-store --query --requisites, and find bash inside the closure.
# Results are stashed in flox_env_closure, flox_env_bash, flox_env_flox_bin,
# and flox_env_project_local for use by the fs-layout and exec blocks below.
#
# In mutable mode we still resolve the env path (for /.flox binding) but
# skip the closure computation — /nix/store is bound rw so there's no need
# to enumerate paths.

flox_env_closure=""
flox_env_bash=""
flox_env_flox_bin=""
flox_env_project_local=""

if [ "$cmd" = "flox-env" ]; then
  [ -n "${HOME:-}" ] \
    || die "flox-env: \$HOME not set on host; cannot construct sandbox home"

  command -v flox >/dev/null 2>&1 \
    || die "flox-env: flox CLI not on PATH"
  flox_env_flox_bin=$(readlink -f "$(command -v flox)" 2>/dev/null)
  [ -x "$flox_env_flox_bin" ] \
    || die "flox-env: resolved flox path not executable: $flox_env_flox_bin"

  # Resolve env seeds.
  if [ -n "$local_env" ]; then
    [ -d "$local_env" ] || die "flox-env: local env not a directory: $local_env"
    flox_env_project_local=$(cd "$local_env" && pwd -P)
    _flox_seeds=$(resolve_local_env "$local_env")
  else
    _flox_seeds=$(resolve_remote_env "$remote_env")
  fi

  if [ "$mutable" = 1 ]; then
    # In mutable mode we skip closure enumeration; whole /nix/store is
    # bound rw.  Still need bash for /bin symlinks, so pick it from the
    # env's run symlink target directly.
    _seed_array=()
    while IFS= read -r _s; do
      [ -n "$_s" ] && _seed_array+=("$_s")
    done <<<"$_flox_seeds"
    # Quick one-seed closure to find bash — cheaper than computing the
    # full closure, but still deterministic.
    if [ "${#_seed_array[@]}" -gt 0 ]; then
      _bash_closure=$(compute_closure "${_seed_array[@]}")
      _bash_array=()
      while IFS= read -r _p; do
        [ -n "$_p" ] && _bash_array+=("$_p")
      done <<<"$_bash_closure"
      if ! flox_env_bash=$(find_bash_in_closure "${_bash_array[@]}"); then
        # Fall back to computing across the flox binary's closure too.
        _bash_array+=("$flox_env_flox_bin")
        _bash_closure=$(compute_closure "${_bash_array[@]}")
        _bash_array=()
        while IFS= read -r _p; do
          [ -n "$_p" ] && _bash_array+=("$_p")
        done <<<"$_bash_closure"
        flox_env_bash=$(find_bash_in_closure "${_bash_array[@]}") \
          || die "flox-env: no bin/bash in env closure or flox closure"
      fi
      unset _bash_closure _bash_array
    else
      die "flox-env: no seed paths resolved from the Flox env"
    fi
    unset _seed_array _s _p
  else
    # Immutable mode: compute the full closure (flox binary + env seeds).
    _seed_array=("$flox_env_flox_bin")
    while IFS= read -r _s; do
      [ -n "$_s" ] && _seed_array+=("$_s")
    done <<<"$_flox_seeds"
    flox_env_closure=$(compute_closure "${_seed_array[@]}")

    # Find bash in the closure.
    _closure_array=()
    while IFS= read -r _p; do
      [ -n "$_p" ] && _closure_array+=("$_p")
    done <<<"$flox_env_closure"
    flox_env_bash=$(find_bash_in_closure "${_closure_array[@]}") \
      || die "flox-env: no bin/bash found in Flox env closure"
    unset _seed_array _closure_array _s _p
  fi
  unset _flox_seeds
fi

# -----------------------------------------------------------------------------
# Build bwrap argument list
# -----------------------------------------------------------------------------
#
# Shape:
#   1. Hardening core (always — namespace setup, userns block,
#      die-with-parent, hostname).  Same across run/agent/flox-env.
#   2. Filesystem layout (mode-dependent).
#      - run/agent:  host-overlaid (/usr, /bin, /sbin, /lib*, /nix all ro-bound;
#                    /etc tmpfs + surgical allowlist; /proc, /dev, /tmp scratch).
#      - flox-env:   Flox-closure-scoped (no host /usr/bin/lib exposure;
#                    tmpfs /nix/store overlay + closure binds; synthetic /bin
#                    and /usr/bin).  Built later after closure resolution.
#   3. Network policy (shared logic, mode default differs).
#   4. Env scrub + mode-specific setenvs.
#   5. User extras.
#   6. Lifecycle fds.
#   7. /etc seal (--remount-ro /etc).
#   8. Seccomp (TIOCSTI BPF).

# 1. Hardening core — always.
args=(
  # Namespaces.  Unshare everything except net (net is handled separately).
  --unshare-user
  --unshare-ipc
  --unshare-pid
  --unshare-uts
  --unshare-cgroup-try

  # Prevent nested user namespaces from inside the sandbox, and refuse to
  # start if the kernel can't enforce that.  Closes the door behind us.
  --disable-userns
  --assert-userns-disabled

  # Lifecycle.  Die with parent so no orphaned sandboxed processes.
  --die-with-parent

  --hostname "$hostname"
)

# 2. Filesystem layout — mode-dependent.
if [ "$cmd" = "run" ] || [ "$cmd" = "agent" ]; then
  # run/agent: host-overlaid.  Expose host /usr, /bin, /sbin, /lib*, /nix
  # read-only; /etc tmpfs with a surgical allowlist; /proc, /dev, /tmp scratch.
  args+=(
    # Filesystem skeleton (read-only).
    --ro-bind /usr /usr
    --ro-bind /bin /bin
    --ro-bind-try /sbin /sbin
    --ro-bind-try /lib  /lib
    --ro-bind-try /lib64 /lib64
    --ro-bind-try /nix /nix

    # /etc: tmpfs with a surgical allowlist bind-mounted on top.  After all
    # binds are in place, --remount-ro makes the underlying tmpfs read-only too,
    # so the agent cannot create arbitrary files under /etc (e.g. ld.so.preload
    # to hijack later children).  The --ro-bind-try entries are independent
    # mount points and remain readable regardless.
    # Critically NOT bound: shadow, sudoers, ssh, pam.d, polkit, gshadow,
    # cron.*, crontab, securetty, and anything else that could disclose host
    # secrets or grant authority.
    --tmpfs /etc
    --ro-bind-try /etc/ld.so.cache    /etc/ld.so.cache
    --ro-bind-try /etc/ld.so.conf     /etc/ld.so.conf
    --ro-bind-try /etc/ld.so.conf.d   /etc/ld.so.conf.d
    --ro-bind-try /etc/nsswitch.conf  /etc/nsswitch.conf
    --ro-bind-try /etc/alternatives   /etc/alternatives
    --ro-bind-try /etc/passwd         /etc/passwd
    --ro-bind-try /etc/group          /etc/group
    --ro-bind-try /etc/host.conf      /etc/host.conf
    --ro-bind-try /etc/localtime      /etc/localtime

    # Minimal /proc and /dev, scratch tmpfs mounts.
    --proc /proc
    --dev /dev
    --tmpfs /tmp
    --tmpfs /var/tmp
    --tmpfs /run
  )
elif [ "$cmd" = "flox-env" ]; then
  # flox-env: Flox-closure-scoped.  No host /usr, /bin, /lib exposure.
  # /etc still tmpfs + surgical allowlist (passwd/group/nsswitch/ld.so.*
  # + /etc/nix for nix.conf).  /nix/store is either closure-scoped (default,
  # immutable) or bound rw (--mutable).  Synthetic /bin and /usr/bin via
  # tmpfs + symlink, pointing at bash in the closure and the flox binary.
  args+=(
    --tmpfs /etc
    --ro-bind-try /etc/ld.so.cache    /etc/ld.so.cache
    --ro-bind-try /etc/ld.so.conf     /etc/ld.so.conf
    --ro-bind-try /etc/ld.so.conf.d   /etc/ld.so.conf.d
    --ro-bind-try /etc/nsswitch.conf  /etc/nsswitch.conf
    --ro-bind-try /etc/alternatives   /etc/alternatives
    --ro-bind-try /etc/passwd         /etc/passwd
    --ro-bind-try /etc/group          /etc/group
    --ro-bind-try /etc/host.conf      /etc/host.conf
    --ro-bind-try /etc/localtime      /etc/localtime
    --ro-bind-try /etc/nix            /etc/nix

    # Minimal /proc and /dev, scratch tmpfs mounts.
    --proc /proc
    --dev /dev
    --tmpfs /tmp
    --tmpfs /var/tmp
    --tmpfs /run

    # Ephemeral home — a tmpfs at the host's $HOME path.  Mode-specific
    # bindings below will layer ~/.config/flox and ~/.local/share/flox
    # into this tmpfs.
    --tmpfs "$HOME"
  )

  # /nix/store visibility.
  if [ "$mutable" = 1 ]; then
    # Mutable: bind /nix/store and /nix/var rw so `flox install` can write
    # via the nix daemon.  Source-build installs will still fail due to
    # --disable-userns (nix-build's own sandbox needs userns), but the
    # common case of cache-hit installs works.
    args+=(
      --bind /nix/store /nix/store
      --bind /nix/var /nix/var
    )
  else
    # Immutable: tmpfs overlay over /nix/store, then surface just the
    # closure paths.  /nix/var is NOT bound (reduces info exposure); a
    # read-only bind of /nix/var/nix/db is sufficient for nix-store
    # --query to work for introspection inside the sandbox.
    args+=(--tmpfs /nix/store)
    if [ -d /nix/var/nix/db ]; then
      args+=(--ro-bind /nix/var/nix/db /nix/var/nix/db)
    fi
    # Surface each closure path.  bwrap creates mount-point parents
    # automatically, and since we just laid a tmpfs over /nix/store, each
    # --ro-bind here creates a fresh directory entry in the tmpfs pointing
    # at the host's real store path.
    while IFS= read -r _p; do
      [ -n "$_p" ] && args+=(--ro-bind "$_p" "$_p")
    done <<<"$flox_env_closure"
    unset _p
  fi

  # Synthetic /bin with sh/bash symlinking into the closure.
  args+=(
    --tmpfs /bin
    --symlink "$flox_env_bash" /bin/sh
    --symlink "$flox_env_bash" /bin/bash
  )

  # Synthetic /usr/bin with flox symlink.  Note: we tmpfs /usr/bin, NOT
  # /usr — nothing from host /usr/lib or /usr/share leaks in.
  args+=(
    --tmpfs /usr/bin
    --symlink "$flox_env_flox_bin" /usr/bin/flox
  )
fi

# Network policy.
if [ "$net" = "1" ]; then
  # Inherit parent net ns (no --unshare-net).
  args+=(
    --ro-bind-try /etc/resolv.conf      /etc/resolv.conf
    --ro-bind-try /etc/hosts            /etc/hosts
    --ro-bind-try /etc/ssl              /etc/ssl
    --ro-bind-try /etc/ca-certificates  /etc/ca-certificates
    --ro-bind-try /etc/pki              /etc/pki
  )
else
  args+=(--unshare-net)
fi

# Environment: wipe, then allowlist.
args+=(
  --clearenv
  --setenv PATH "/usr/bin:/bin:/usr/sbin:/sbin"
  --setenv TERM "${TERM:-dumb}"
  --setenv LANG "${LANG:-C.UTF-8}"
)

# Mode-specific bindings.
if [ "$cmd" = "agent" ]; then
  # Project bind: rw by default, ro if --project-ro is set (F1).
  if [ "$project_ro" = 1 ]; then
    args+=(--ro-bind "$project" "$project_as")
  else
    args+=(--bind    "$project" "$project_as")
  fi
  args+=(
    --bind "$agent_home" "$agent_home"
    --setenv HOME "$agent_home"
    --setenv TMPDIR "/tmp"
    --chdir "$project_as"
  )

  # Inherit the host $PATH so that Flox- and Nix-installed commands
  # ($FLOX_ENV/bin, /nix/var/nix/profiles/default/bin, etc.) resolve
  # normally inside the jail.  Fall back to the minimal PATH from the
  # base stanza if the host has none.  Later --setenv wins, per bwrap.
  if [ -n "${PATH:-}" ]; then
    args+=(--setenv PATH "$PATH")
  fi

  # Pass host ~/.gitconfig ro, if present — convenience for git-using agents.
  # Rejected: ~/.git-credentials, ~/.netrc (auth material).
  if [ -n "${HOME:-}" ] && [ -f "$HOME/.gitconfig" ]; then
    args+=(--ro-bind "$HOME/.gitconfig" "$agent_home/.gitconfig")
  fi

  # Pass through each named env var if the host has it set.  Unset vars
  # are silently skipped (no --setenv emitted), so the jail sees only the
  # vars actually present on the host.  The reserved-name check above
  # already rejected anything that would override the jail baseline.
  for _pte in "${passthrough_envs[@]}"; do
    [ -z "$_pte" ] && continue
    _pte_val=${!_pte:-}
    if [ -n "$_pte_val" ]; then
      args+=(--setenv "$_pte" "$_pte_val")
    fi
  done
  unset _pte _pte_val

  # NOTE: we deliberately do NOT pass --new-session in agent mode.  It calls
  # setsid() and detaches from the controlling tty, which breaks interactive
  # CLIs like Claude Code.  The TIOCSTI class of attack is instead mitigated
  # by the seccomp BPF filter loaded below (see gen-seccomp.c), which blocks
  # ioctl(_, TIOCSTI, _) with EPERM regardless of kernel version.
  #
  # Belt-and-braces at the kernel level: on Linux 6.2+, injecting characters
  # into another process's tty via TIOCSTI requires CAP_SYS_ADMIN when the
  # dev.tty.legacy_tiocsti sysctl is false (the default on modern distros).
  # That is independent of our seccomp filter.  But if --no-seccomp is passed
  # on an older kernel, or on a host that has flipped dev.tty.legacy_tiocsti
  # to true for compatibility reasons, TIOCSTI is unfiltered — so don't
  # disable seccomp unless you've verified your kernel's TIOCSTI policy.
elif [ "$cmd" = "flox-env" ]; then
  # flox-env mode: ephemeral HOME tmpfs (laid by the fs block above),
  # Flox config mounts, interactive tty preserved (no --new-session —
  # TIOCSTI seccomp handles the injection class instead), no host PATH
  # inheritance (PATH is whatever the baseline env block set, typically
  # /usr/bin:/bin after the override below).
  args+=(
    --setenv HOME "$HOME"
    --setenv TMPDIR "/tmp"
    --setenv PATH "/usr/bin:/bin"
    --setenv USER "${USER:-user}"
    --setenv SHELL "/bin/bash"
    --setenv FLOX_SHELL "bash"
    --chdir "$HOME"
  )

  # Flox config bindings.  ~/.config/flox bound ro because it contains auth
  # tokens for remote catalogs — a compromised in-sandbox process could
  # read them, which we accept as the cost of making `flox` commands work
  # inside the sandbox.  ~/.local/share/flox bound rw because flox writes
  # registry lock files there.
  if [ -d "$HOME/.config/flox" ]; then
    args+=(--ro-bind "$HOME/.config/flox" "$HOME/.config/flox")
  fi
  if [ -d "$HOME/.local/share/flox" ]; then
    args+=(--bind "$HOME/.local/share/flox" "$HOME/.local/share/flox")
  fi

  # Env reference: local envs get their .flox bound to /.flox (so we can
  # activate -d /); remote envs get ~/.cache/flox bound so the pulled
  # env is reachable from inside.
  if [ -n "$local_env" ]; then
    args+=(--bind "$flox_env_project_local/.flox" "/.flox")
  else
    if [ -d "$HOME/.cache/flox" ]; then
      args+=(--bind "$HOME/.cache/flox" "$HOME/.cache/flox")
    fi
  fi

  # Passthrough env vars (same semantics as agent mode).
  for _pte in "${passthrough_envs[@]}"; do
    [ -z "$_pte" ] && continue
    _pte_val=${!_pte:-}
    if [ -n "$_pte_val" ]; then
      args+=(--setenv "$_pte" "$_pte_val")
    fi
  done
  unset _pte _pte_val

  # Optional resource passthroughs.  Each is guarded on host presence so
  # they're no-ops if the host lacks the relevant bits.
  if [ "$x11" = 1 ] && [ -n "${DISPLAY:-}" ]; then
    # Extract display number: ":0" → "0", ":0.1" → "0".
    _xnum=${DISPLAY#*:}
    _xnum=${_xnum%%.*}
    args+=(--setenv DISPLAY "$DISPLAY")
    if [ -S "/tmp/.X11-unix/X$_xnum" ]; then
      args+=(--ro-bind "/tmp/.X11-unix/X$_xnum" "/tmp/.X11-unix/X$_xnum")
    fi
    if [ -f "$HOME/.Xauthority" ]; then
      args+=(--ro-bind "$HOME/.Xauthority" "$HOME/.Xauthority")
    fi
    unset _xnum
  fi
  if [ "$gpu" = 1 ]; then
    [ -d /dev/dri ] && args+=(--dev-bind /dev/dri /dev/dri)
    [ -d /sys/dev/char ] && args+=(--ro-bind /sys/dev/char /sys/dev/char)
    [ -d /sys/devices/pci0000:00 ] && args+=(--ro-bind /sys/devices/pci0000:00 /sys/devices/pci0000:00)
    [ -d /run/opengl-driver ] && args+=(--ro-bind /run/opengl-driver /run/opengl-driver)
  fi
  if [ "$dev_shm" = 1 ] && [ -d /dev/shm ]; then
    args+=(--dev-bind /dev/shm /dev/shm)
  fi

  # Mutable mode warning (printed to stderr just before exec in non-dry-run
  # mode; dry-run mode still prints it so users see the warning when
  # reviewing the sandbox policy).
  if [ "$mutable" = 1 ]; then
    printf '%s: mutable mode: /nix/store and /nix/var are bound read-write; sandbox can mutate the host nix database\n' \
      "$prog" >&2
  fi
else
  # run mode: neutral HOME, scratch cwd, new session (no interactive tty needs).
  args+=(
    --setenv HOME "/tmp"
    --setenv TMPDIR "/tmp"
    --chdir /tmp
    --new-session
  )
fi

# User-supplied extras appended last so they can override earlier setenvs.
i=0
while [ $i -lt ${#extra_bind[@]} ]; do
  args+=(--bind "${extra_bind[i]}" "${extra_bind[i+1]}")
  i=$((i + 2))
done

i=0
while [ $i -lt ${#extra_ro_bind[@]} ]; do
  args+=(--ro-bind "${extra_ro_bind[i]}" "${extra_ro_bind[i+1]}")
  i=$((i + 2))
done

i=0
while [ $i -lt ${#extra_setenv[@]} ]; do
  args+=(--setenv "${extra_setenv[i]}" "${extra_setenv[i+1]}")
  i=$((i + 2))
done

# Lifecycle / orchestration pass-throughs (V1).
#
#   --lock-file PATH: bwrap takes an exclusive flock on PATH for the
#     lifetime of the sandbox.  A parent process can wait for the lock
#     to be released to know when the sandbox exits.  bwrap opens PATH
#     from INSIDE the jail's filesystem view (after namespace setup),
#     so we auto-bind PATH (rw) at the same path so it's reachable.
#     IF the user has already bound PATH themselves (via --bind or
#     --ro-bind with the same jail-side destination), we skip the
#     auto-bind and just append --lock-file — so the user can supply
#     the lock file from a different source without our auto-bind
#     shadowing their intent.  The user is responsible for creating
#     the file on the host before invocation; bwrap will not create it.
#
#   --sync-fd FD: bwrap holds FD open for the lifetime of the sandbox.
#     When the sandbox exits, the fd closes — so a parent reading the
#     other end of a pipe sees EOF and knows the sandbox is gone.  FD
#     must already be open in the parent and inherited by the wrapper
#     (e.g. `bwrap-jail … --sync-fd 9 9>pipe`).
#
#   --info-fd FD: bwrap writes a JSON metadata blob to FD after setup
#     completes, then closes it.  The JSON contains the sandboxed
#     child's host-side PID among other fields (see bwrap(1) for the
#     schema).  Useful for orchestrators that want structured sandbox
#     info without parsing bwrap's stderr.  FD must already be open in
#     the parent and inherited by the wrapper.
if [ -n "$lock_file" ]; then
  # Check whether the user already bound this jail-side path.
  _lock_user_bound=0
  i=0
  while [ $i -lt ${#extra_bind[@]} ]; do
    if [ "${extra_bind[i+1]}" = "$lock_file" ]; then
      _lock_user_bound=1
      break
    fi
    i=$((i + 2))
  done
  if [ "$_lock_user_bound" = 0 ]; then
    i=0
    while [ $i -lt ${#extra_ro_bind[@]} ]; do
      if [ "${extra_ro_bind[i+1]}" = "$lock_file" ]; then
        _lock_user_bound=1
        break
      fi
      i=$((i + 2))
    done
  fi
  if [ "$_lock_user_bound" = 0 ]; then
    args+=(--bind "$lock_file" "$lock_file" --lock-file "$lock_file")
  else
    args+=(--lock-file "$lock_file")
  fi
  unset _lock_user_bound
fi
[ -n "$sync_fd" ] && args+=(--sync-fd "$sync_fd")
[ -n "$info_fd" ] && args+=(--info-fd "$info_fd")

# Seal /etc: remount the tmpfs backing /etc as read-only.  This does NOT
# recurse into the bind mounts layered on top, so the baseline allowlist
# stays readable.  Placed AFTER the user --bind / --ro-bind loops so that
# user binds into /etc create their mount points before the parent tmpfs
# turns read-only — bwrap can't mkdir a mount point on a ro filesystem.
args+=(--remount-ro /etc)

# Dependency check lives here (not at the top) so --help and early arg errors
# work even when bwrap isn't installed.
command -v bwrap >/dev/null 2>&1 || die "bwrap not found in PATH"

# Attach the seccomp TIOCSTI filter.  Blocks ioctl(_, TIOCSTI, _) with EPERM,
# closing the TTY-injection attack class without --new-session (which would
# break interactive agent use).  See src/gen-seccomp.c for the filter.
#
# Three failure modes, three handlers:
#
#   1. BPF_PATH placeholder unsubstituted (running from unbuilt source):
#      print a warning, continue without the filter.
#   2. BPF file missing or unreadable (package broken / store path nuked):
#      die with a clear message before exec.
#   3. BPF file present but bwrap rejects it (truncated blob, kernel ABI
#      mismatch, libseccomp version skew): pre-flight probe in a minimal
#      bwrap invocation, die with a clear message before the real exec.
#
# The pre-flight in (3) costs one extra bwrap fork (~50ms) but means the
# user sees "seccomp BPF rejected by bwrap (...)" from this script with
# context, instead of a bare bwrap stderr line they have to interpret
# from a process we've already exec'd into.
#
# If --no-seccomp was passed, all of the above is skipped silently.
if [ "$seccomp_enabled" = "1" ]; then
  # Detect substitution by shape: a real nix store path starts with "/";
  # the unsubstituted placeholder starts with "@".  We cannot compare
  # $BPF_PATH against the unsubstituted placeholder as a literal string
  # because sed's global replace in the build step would rewrite any
  # copy of that placeholder in this file — including a copy here in
  # the code that's checking for it — defeating the check.
  case "$BPF_PATH" in
    /*)
      if [ ! -r "$BPF_PATH" ]; then
        die "seccomp BPF not readable: $BPF_PATH (package broken?)"
      fi
      # Pre-flight: ask bwrap to load this exact blob in a throwaway
      # sandbox before we exec the real one.  fd 11 is local here; the
      # real exec below uses fd 10.  Capture bwrap's stderr so that if
      # the probe fails for a reason OTHER than seccomp rejection (e.g.
      # a kernel that no longer supports --disable-userns), we can
      # include bwrap's own error in our die message instead of
      # blaming the BPF blob generically.
      #
      # `if ! x=$(cmd)` is the idiom we need here: it bypasses `set -e`
      # on a failed command substitution (which would otherwise kill
      # the script silently before we reach the die message), while
      # still capturing the command's stderr into $x.
      if [ "$dry_run" != 1 ]; then
        if ! _seccomp_probe_err=$(
          bwrap --ro-bind / / --disable-userns --assert-userns-disabled \
                --unshare-user --unshare-pid --die-with-parent \
                --seccomp 11 11<"$BPF_PATH" \
                true 2>&1 >/dev/null
        ); then
          die "seccomp BPF rejected by bwrap: $BPF_PATH (${_seccomp_probe_err:-no stderr from bwrap})"
        fi
        unset _seccomp_probe_err
        # Open on fd 10 and pass to bwrap.  bwrap inherits non-cloexec fds,
        # and bash's `exec N<file` form does not set cloexec by default.
        exec 10<"$BPF_PATH"
      fi
      args+=(--seccomp 10)
      ;;
    *)
      printf '%s: warning: running from unbuilt source, TIOCSTI seccomp filter not applied (use --no-seccomp to silence)\n' \
        "$prog" >&2
      ;;
  esac
fi

# Compose the final command line inside the sandbox.  For flox-env mode
# (unless --no-activate) we wrap the user command in `flox activate` so the
# sandboxed process runs inside the activated env's shell environment.
if [ "$cmd" = "flox-env" ] && [ "$no_activate" = 0 ]; then
  if [ -n "$local_env" ]; then
    final_cmd=(flox activate -d / -- "$@")
  else
    final_cmd=(flox activate -r "$remote_env" -- "$@")
  fi
else
  final_cmd=("$@")
fi

# Dry-run: print the bwrap argv to stdout and exit without execing.  Uses
# %q quoting so the output is re-runnable as a shell command.  Skipped in
# non-flox-env modes because --dry-run is rejected there by the validation
# block above.
if [ "$dry_run" = 1 ]; then
  printf 'bwrap'
  for _arg in "${args[@]}"; do
    printf ' %q' "$_arg"
  done
  printf ' --'
  for _arg in "${final_cmd[@]}"; do
    printf ' %q' "$_arg"
  done
  printf '\n'
  exit 0
fi

exec bwrap "${args[@]}" -- "${final_cmd[@]}"
